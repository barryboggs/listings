# =============================================================================
# Listing Manager — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values

# -----------------------------------------------------------------------------
# AUTH — Required
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# -----------------------------------------------------------------------------
# SEMRUSH API — Required for live data (app runs in demo mode without these)
# -----------------------------------------------------------------------------

# Option 1: Manual Bearer Token (quickest for testing)
# Get this from Semrush API settings or by running the OAuth flow once
SEMRUSH_BEARER_TOKEN=

# Option 2: Full OAuth (production)
# Register an app at Semrush to get these credentials
# SEMRUSH_CLIENT_ID=
# SEMRUSH_REFRESH_TOKEN=

# API base URL (you shouldn't need to change this)
# SEMRUSH_API_BASE=https://api.semrush.com/apis/v4-raw/listing-management/v1
