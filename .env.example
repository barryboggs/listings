# Copy this file to .env.local and fill in values

# Auth secret — generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# Semrush API (for production - not needed for demo)
# SEMRUSH_BEARER_TOKEN=your_bearer_token_here
# SEMRUSH_API_BASE=https://api.semrush.com/apis/v4-raw/listing-management/v1
